{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["local>home-operations/renovate-config"],
  packageRules: [
    {
      description: "Disable Auto Merge",
      matchManagers: ["mise"],
      matchPackageNames: ["rust", "cargo-llvm-cov", "cargo-deny", "kopia"],
      automerge: false,
    },
  ],
}
