+    wait_phase(&repos, repo_name, "Ready")
+        .await
+        .expect("server Repository should reach Ready");
+    wait_until(
+        "status.server.endpoint is pinned",
+        default_timeout(),
+        poll_interval(),
+        || async {
+            let s = status_json(&repos, repo_name).await;
+            let ep = s
+                .get("server")
+                .and_then(|sv| sv.get("endpoint"))
+                .and_then(|v| v.as_str())
+                .unwrap_or("");
+            Ok((!ep.is_empty()).then_some(()))
