+    /// Listen address — must be non-loopback (e.g. `0.0.0.0:51515`) to be reachable
+    /// through a Service.
+    pub address: String,
+    /// UI authentication mode.
+    pub auth: ServerAuthMode,
+    /// Serve the embedded HTML UI (`--ui`). Defaults to enabled.
+    pub ui: bool,
+}
